<?xml version="1.0" encoding="utf-8"?>
<!-- activity_setup.xml — Fragment host for SetupActivity.java.
     Contains ONLY the FrameLayout container that the 3 onboarding fragments swap into.
     The top header (helmet + tagline) is repeated in each fragment so it can be
     customised per step; alternatively move it here if you want it fixed. -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B4B">

    <!--
        IMPORTANT: This ID must match CONTAINER_ID in SetupActivity.java:
            private static final int CONTAINER_ID = R.id.fragment_container;
    -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
