<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_gray"
    android:padding="16dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tvRepDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Date String"
        android:textColor="#000000"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvRepStats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0.0 km • 0.0 Km/L"
        android:textColor="#000000"
        android:textStyle="bold"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvRepDate" />

    <TextView
        android:id="@+id/tvRepProfit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+ ₱0"
        android:textColor="#2E7D32"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvRepGas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gas: ₱0"
        android:textColor="#666666"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvRepProfit" />

</androidx.constraintlayout.widget.ConstraintLayout>