<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_setup_motorcycle.xml — Links to MotorcycleSetupFragment.java (Onboarding Step 2) -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B4B"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Top bar: back arrow + logo + tagline ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back"
                android:background="@drawable/bg_back_button"
                android:tint="#FFFFFF" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_helmet"
                android:contentDescription="Logo"
                android:layout_marginStart="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Let's finish setting up your account!"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- ── Motorcycle card ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#1A2D6B"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Card title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Motorcycle"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_gravity="center_horizontal" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="We'll use this to track your fuel and maintenance."
                    android:textColor="#AABBDD"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="28dp" />

                <!-- Make / Brand -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Brand / Make"
                    android:textColor="#AABBDD"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_moto_brand"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="14dp"
                    android:textColor="#FFFFFF"
                    android:hint="e.g. Honda, Yamaha"
                    android:textColorHint="#6B7DB3"
                    android:layout_marginBottom="16dp" />

                <!-- Model -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Model"
                    android:textColor="#AABBDD"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_moto_model"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="14dp"
                    android:textColor="#FFFFFF"
                    android:hint="e.g. Beat, Mio, Click"
                    android:textColorHint="#6B7DB3"
                    android:layout_marginBottom="16dp" />

                <!-- Year -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Year"
                    android:textColor="#AABBDD"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_moto_year"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="14dp"
                    android:textColor="#FFFFFF"
                    android:hint="e.g. 2021"
                    android:textColorHint="#6B7DB3"
                    android:inputType="number"
                    android:layout_marginBottom="16dp" />

                <!-- Plate Number -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plate Number"
                    android:textColor="#AABBDD"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/et_moto_plate"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="14dp"
                    android:textColor="#FFFFFF"
                    android:hint="e.g. ABC 1234"
                    android:textColorHint="#6B7DB3"
                    android:inputType="textCapCharacters"
                    android:layout_marginBottom="28dp" />

                <!-- Next button -->
                <Button
                    android:id="@+id/btn_next"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Next"
                    android:textColor="#0D1B4B"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#F5A623" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
