<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B4B"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_helmet_rider"
                android:contentDescription="Rider avatar" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Let's finish\nsetting up\nyour account!"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1A2D6B"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Date of Birth"
                            android:textColor="#AABBDD"
                            android:textSize="13sp"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/et_date_of_birth"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_input_field"
                            android:paddingHorizontal="12dp"
                            android:textColor="#FFFFFF"
                            android:hint="MM/DD/YYYY"
                            android:textColorHint="#6B7DB3"
                            android:focusable="false"
                            android:clickable="true" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btn_calendar"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_calendar"
                        android:contentDescription="Pick date"
                        android:background="@drawable/bg_input_field"
                        android:tint="#AABBDD"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="18dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Type of Valid ID"
                            android:textColor="#AABBDD"
                            android:textSize="13sp"
                            android:layout_marginBottom="4dp" />

                        <Spinner
                            android:id="@+id/spinner_valid_id_type"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_input_field"
                            android:paddingHorizontal="12dp"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ID no."
                            android:textColor="#AABBDD"
                            android:textSize="13sp"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/et_id_number"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_input_field"
                            android:paddingHorizontal="12dp"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#6B7DB3"
                            android:inputType="text" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/layout_upload_id"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_field"
                        android:clickable="true"
                        android:focusable="true"
                        android:clipToOutline="true">

                        <!-- Full image bleeds to the edge safely behind text if needed -->
                        <ImageView
                            android:id="@+id/iv_id_photo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_upload"
                            android:contentDescription="Upload ID"
                            app:tint="#AABBDD" />

                        <!-- Upload label container fixed to bottom -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:gravity="center"
                            android:paddingVertical="8dp">

                            <TextView
                                android:id="@+id/tv_upload_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tap to upload ID"
                                android:textColor="#AABBDD"
                                android:background="#CC1A2D6B"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:textSize="12sp"
                                android:gravity="center" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1A2D6B"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rider Work Details"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_gravity="center_horizontal" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tell us how you work."
                    android:textColor="#AABBDD"
                    android:textSize="13sp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delivery Platforms"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_platforms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:singleSelection="false">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_foodpanda"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FoodPanda"
                        android:textColor="#AABBDD"
                        android:checkable="true"
                        app:chipBackgroundColor="#2A3F8F"
                        app:chipStrokeWidth="0dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_lalamove"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lalamove"
                        android:textColor="#AABBDD"
                        android:checkable="true"
                        app:chipBackgroundColor="#2A3F8F"
                        app:chipStrokeWidth="0dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_maxim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Maxim"
                        android:textColor="#AABBDD"
                        android:checkable="true"
                        app:chipBackgroundColor="#2A3F8F"
                        app:chipStrokeWidth="0dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_grab"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grab"
                        android:textColor="#AABBDD"
                        android:checkable="true"
                        app:chipBackgroundColor="#2A3F8F"
                        app:chipStrokeWidth="0dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_others"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ others"
                        android:textColor="#AABBDD"
                        android:checkable="true"
                        app:chipBackgroundColor="#2A3F8F"
                        app:chipStrokeWidth="0dp" />

                </com.google.android.material.chip.ChipGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rider Type"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <Button
                        android:id="@+id/btn_full_time"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Full-Time"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:backgroundTint="#2A3F8F"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btn_part_time"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Part-Time"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:backgroundTint="#2A3F8F"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btn_freelance"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Freelance"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:backgroundTint="#2A3F8F" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Area of Operation"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_input_field"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <EditText
                            android:id="@+id/et_area_of_operation"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:paddingHorizontal="12dp"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#6B7DB3"
                            android:hint="Search area..." />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_search"
                            android:contentDescription="Search"
                            app:tint="#AABBDD"
                            android:layout_marginEnd="12dp" />
                    </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Earnings Target (₱)"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_daily_earnings_target"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#6B7DB3"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="24dp" />

                <Button
                    android:id="@+id/btn_next"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Next"
                    android:textColor="#0D1B4B"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#F5A623" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/btn_maybe_later"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Maybe, later"
            android:textColor="#AABBDD"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
</ScrollView>